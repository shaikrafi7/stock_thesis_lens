# Required API keys
OPENAI_API_KEY=sk-...
POLYGON_API_KEY=
TAVILY_API_KEY=

# Optional API keys
SERPER_API_KEY=
FMP_API_KEY=
FINANCIAL_DATASETS_API_KEY=
LANGSMITH_API_KEY=

# Database (SQLite for local dev, PostgreSQL for production)
DATABASE_URL=sqlite:///./stock_thesis.db
# DATABASE_URL=postgresql://user:pass@host:5432/thesisarc

# Auth
SECRET_KEY=change-me-in-production-use-a-real-secret

# CORS (comma-separated origins)
CORS_ORIGINS=http://localhost:3000

# LangSmith tracing (optional)
LANGCHAIN_TRACING_V2=false
LANGCHAIN_PROJECT=stock-thesis-lens
